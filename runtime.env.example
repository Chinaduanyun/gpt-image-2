# Copy to runtime.env. Never place real secrets in this example file.
ADMIN_EMAIL=admin@example.com
API_MARKET_API_KEY=replace-with-secret
API_MARKET_BASE_URL=https://api.apimart.ai
API_MARKET_MODEL=gpt-image-2

# Default false. When true, gpt-image-2 n=2..4 creates N flat generation logs
# linked by batchId and submits N simultaneous upstream n=1 requests.
# Official gpt-image-2-official n=1..4 is unaffected by this flag.
QUICK_BATCH_ENABLED=false

PRICING_CURRENCY_RATE=10
PRICING_MARKUP_MULTIPLIER=3.6
PRICING_TOTAL_MULTIPLIER=36
PRICING_GPT_IMAGE_2_TOTAL_MULTIPLIER=36
PRICING_GPT_IMAGE_2_MINIMUM_PER_IMAGE_MICROS=300000
PRICING_GPT_IMAGE_2_OFFICIAL_TOTAL_MULTIPLIER=10.5
PRICING_GPT_IMAGE_2_OFFICIAL_MINIMUM_PER_IMAGE_MICROS=300000
PRICING_LEGACY_TOTAL_MULTIPLIER=50
PRICING_VERSION=2026-07-10-model-policy-v1
